{
  "manifest_version": 3,
  "name": "DogDrip Attachment Bulk Downloader",
  "description": "개드립 게시글의 첨부 이미지와 동영상을 툴바에서 한 번에 다운로드합니다.",
  "version": "0.1.5",
  "action": {
    "default_title": "개드립 첨부파일 일괄 다운로드",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-128.png",
      "24": "icons/icon-128.png",
      "32": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-128.png",
    "32": "icons/icon-128.png",
    "48": "icons/icon-128.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  },
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["https://www.dogdrip.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.dogdrip.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
